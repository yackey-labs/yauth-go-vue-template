# Copy to .env and adjust as needed.
# Loaded by Taskfile.yml via `dotenv:`, so every ./task target sees these.

# Postgres DSN — referenced by yauth.yaml as `env:DATABASE_URL`. The
# value below matches the docker-compose service in this repo.
DATABASE_URL=postgres://yauth:yauth@127.0.0.1:5432/yauth_app?sslmode=disable

# OTLP collector for OpenTelemetry exports. yauth-go's telemetry.Init
# reads this directly when yauth.yaml's telemetry.otlp_endpoint is
# blank, so the same yauth.yaml ships dev/prod and the env var picks
# the right collector.
#
#   dev:  https://otel-local.yackey.cloud
#   prod: https://otel.yackey.cloud   (set via your secret/env manager)
#
# Leave it commented to disable export (yauth uses the no-op tracer).
OTEL_EXPORTER_OTLP_ENDPOINT=https://otel-local.yackey.cloud
OTEL_SERVICE_NAME=yauth-go-vue-template

# Frontend telemetry. Vite only exposes env vars prefixed with VITE_
# to the browser bundle, so these are deliberately separate even
# though they typically point at the same collector. Leave blank to
# disable browser-side OTel (web/src/otel.ts becomes a no-op).
VITE_OTEL_EXPORTER_OTLP_ENDPOINT=https://otel-local.yackey.cloud
VITE_OTEL_SERVICE_NAME=yauth-go-vue-template-web
