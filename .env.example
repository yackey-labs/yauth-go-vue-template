# Copy to .env and adjust as needed.
# `make dev` reads this via godotenv-style loading in cmd/server.

# Postgres connection string. The DSN format below matches the docker-compose
# database service in this repo; if you point at an external Postgres, swap it
# in here.
DATABASE_URL=postgres://yauth:yauth@127.0.0.1:5432/yauth_app?sslmode=disable

# HTTP listener for the Go backend.
PORT=3000

# Comma-separated list of origins allowed to call the API directly (no Vite
# proxy). Leave empty when using the Vite proxy in dev.
CORS_ORIGINS=

# Local dev convenience: turn HIBP off so example/test passwords don't get
# rejected. Leave unset (or set to "true") in production.
DISABLE_HIBP=true
